@import '../icon.wxss';

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  display: flex;
  border-top: 1rpx solid #e7e7e7;
  box-sizing: border-box;
  z-index: 9999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 12rpx;
}

.tab-bar-icon {
  font-size: 48rpx;
  line-height: 1;
  margin-bottom: 6rpx;
}

.tab-bar-text {
  font-size: 20rpx;
  line-height: 1.2;
}
