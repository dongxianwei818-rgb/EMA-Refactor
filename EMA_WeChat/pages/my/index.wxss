@import "./kv-pill.wxss";

.profile-card {
  position: relative;
}

.profile-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0;
}

.profile-card.is-expanded .profile-card-head {
  margin-bottom: 8rpx;
}

.profile-card-head-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.profile-card-head .section-title {
  margin: 0;
  padding: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 44rpx;
}

.section-chevron {
  width: 44rpx;
  height: 44rpx;
  margin-left: 4rpx;
  flex-shrink: 0;
  position: relative;
  box-sizing: border-box;
}

.section-chevron::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 12rpx;
  height: 12rpx;
  margin-left: -6rpx;
  margin-top: -9rpx; /* 向下箭头视觉居中 */
  border-right: 3rpx solid #bbb;
  border-bottom: 3rpx solid #bbb;
  box-sizing: border-box;
  transform: rotate(45deg);
  transition: transform 0.2s ease, margin-top 0.2s ease;
}

.section-chevron.is-open::after {
  margin-top: -3rpx; /* 向上箭头视觉居中 */
  transform: rotate(225deg);
}

.profile-card-body {
  padding-top: 4rpx;
}

.profile-more {
  font-size: 24rpx;
  color: #07c160;
}

.profile-id {
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
  line-height: 1.4;
  margin: 8rpx 0 8rpx;
}

.kv-list {
  margin-top: 4rpx;
}

.kv-footnote {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
}

.profile-empty {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
  margin-top: 8rpx;
}

.my-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 8rpx;
}

.my-action-btn {
  width: 48% !important;
  box-sizing: border-box;
  margin: 0 0 16rpx !important;
  padding-left: 8rpx !important;
  padding-right: 8rpx !important;
  font-size: 26rpx !important;
  line-height: 2.1 !important;
}
