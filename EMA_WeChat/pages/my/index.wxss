.profile-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f2f4;
}

.profile-row:last-child {
  border-bottom: none;
}

.profile-label {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  padding-right: 16rpx;
}

.profile-value {
  flex-shrink: 0;
  max-width: 55%;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
  line-height: 1.5;
  word-break: break-all;
}

.profile-id {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.profile-empty {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.profile-card {
  position: relative;
}

.profile-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.profile-card-head .section-title {
  margin-bottom: 0;
}

.profile-more {
  font-size: 24rpx;
  color: #07c160;
}
