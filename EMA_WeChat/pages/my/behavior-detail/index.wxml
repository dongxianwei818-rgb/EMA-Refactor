<view class="page-pad">
  <view class="card kv-card" wx:if="{{hasData}}">
    <block wx:for="{{sections}}" wx:key="id">
      <view class="section-title">{{item.title}}</view>
      <view class="kv-list">
        <view
          class="profile-row {{rowIndex === item.rows.length - 1 ? 'is-last' : ''}}"
          wx:for="{{item.rows}}"
          wx:for-item="row"
          wx:for-index="rowIndex"
          wx:key="label"
        >
          <text class="profile-label label-{{row.id}}">{{row.label}}</text>
          <text class="profile-value">{{row.value}}</text>
        </view>
      </view>
    </block>
  </view>
  <view class="card" wx:else>
    <view class="profile-empty">暂无使用行为记录。</view>
  </view>
</view>
