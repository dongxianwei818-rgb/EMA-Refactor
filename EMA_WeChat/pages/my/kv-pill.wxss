/* 详情页 KV 列表：左侧彩色胶囊标签（与「我的」页一致） */
.kv-list .profile-row,
.kv-card .profile-row {
  display: flex;
  align-items: center;
  min-height: 80rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f2f4;
  gap: 20rpx;
}

.kv-list .profile-row.is-last,
.kv-card .profile-row.is-last {
  border-bottom: none;
}

.profile-label.pill,
.kv-list .profile-label,
.kv-card .profile-label {
  flex: 0 0 auto;
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 18rpx;
  border-radius: 12rpx;
  text-align: center;
  line-height: 1.3;
  /* max-width: 240rpx; */
  background: #f5f5f5;
  color: #595959;
}

.profile-value.pill-value,
.kv-list .profile-value,
.kv-card .profile-value {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
  line-height: 1.5;
  word-break: break-word;
}

