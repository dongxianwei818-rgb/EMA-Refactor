<view class="page-pad">
  <view class="card" wx:if="{{hasBaseline}}">
    <view class="hint baseline-time" wx:if="{{baselineTimeStr}}">基线测评完成时间：{{baselineTimeStr}}</view>
    <block wx:for="{{sections}}" wx:key="id">
      <view class="section-title">{{item.title}}</view>
      <view class="profile-row" wx:for="{{item.rows}}" wx:for-item="row" wx:key="label">
        <text class="profile-label">{{row.label}}</text>
        <text class="profile-value">{{row.value}}</text>
      </view>
    </block>
  </view>
  <view class="card" wx:else>
    <view class="profile-empty">尚未完成基线测评，暂无档案详情。</view>
  </view>
</view>
