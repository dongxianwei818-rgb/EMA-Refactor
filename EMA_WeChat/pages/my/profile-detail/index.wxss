.profile-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f2f4;
}

.profile-row:last-child {
  border-bottom: none;
}

.profile-label {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  padding-right: 16rpx;
}

.profile-value {
  flex-shrink: 0;
  max-width: 55%;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
  line-height: 1.5;
  word-break: break-all;
}

.baseline-time {
  margin-bottom: 16rpx;
}

.profile-empty {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin: 24rpx 0 8rpx;
}

.section-title:first-child {
  margin-top: 0;
}
