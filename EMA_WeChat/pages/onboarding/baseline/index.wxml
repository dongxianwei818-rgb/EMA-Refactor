<view class="page-pad">
  <view class="hint" style="background:#fff8e6;padding:20rpx;border-radius:12rpx;margin-bottom:24rpx;">
    基线测评仅采集一次。回答越详细，预测越准确。
  </view>
  <block wx:for="{{sections}}" wx:key="id">
    <view class="section-title">{{item.title}}</view>
    <view class="hint" wx:if="{{item.hint}}">{{item.hint}}</view>
    <view class="card" wx:if="{{item.fields}}">
      <view wx:for="{{item.fields}}" wx:for-item="f" wx:key="id" style="margin-bottom:24rpx;">
        <text style="display:block;margin-bottom:8rpx;">{{f.label}}<text wx:if="{{f.required}}" class="required-mark"> *</text></text>
        <input wx:if="{{f.type==='input'}}" type="{{f.inputType||'text'}}" placeholder="请输入" value="{{form[f.id]}}" data-id="{{f.id}}" bindinput="onInput" style="background:#f5f5f5;padding:16rpx;border-radius:8rpx;" />
        <radio-group wx:if="{{f.type==='radio'}}" data-id="{{f.id}}" bindchange="onRadio">
          <label wx:for="{{f.options}}" wx:for-item="opt" wx:key="*this" style="display:block;padding:8rpx 0;">
            <radio value="{{opt}}" checked="{{form[f.id]===opt}}" />{{opt}}
          </label>
        </radio-group>
      </view>
    </view>
    <view class="card" wx:if="{{item.items}}">
      <view wx:for="{{item.items}}" wx:for-item="q" wx:key="id" style="margin-bottom:24rpx;">
        <text style="display:block;margin-bottom:8rpx;">{{q.label}}<text wx:if="{{!q.optional}}" class="required-mark"> *</text><text wx:if="{{q.optional}}">（选填）</text></text>
        <radio-group data-id="{{q.id}}" bindchange="onRadio">
          <label wx:for="{{q.options}}" wx:for-item="opt" wx:key="*this" style="display:block;padding:6rpx 0;font-size:26rpx;">
            <radio value="{{opt}}" checked="{{form[q.id]===opt}}" />{{opt}}
          </label>
        </radio-group>
      </view>
    </view>
  </block>
  <view class="baseline-submit">
    <button class="btn-primary baseline-submit-btn" bindtap="onSubmit">完成基线采集</button>
    <view class="baseline-submit-hint">仅采集一次</view>
  </view>
</view>
