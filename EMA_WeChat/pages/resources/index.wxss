.resources-page {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.resources-banner {
  background: linear-gradient(135deg, #722ed1 0%, #531dab 100%);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 32rpx;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(114, 46, 209, 0.25);
}

.resources-banner-title {
  font-size: 34rpx;
  font-weight: 700;
}

.resources-banner-sub {
  font-size: 24rpx;
  opacity: 0.88;
  margin-top: 12rpx;
}

.resources-section .hint {
  margin-bottom: 8rpx;
}

.resource-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f2f4;
}

.resource-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.resource-main {
  flex: 1;
  min-width: 0;
}

.resource-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.resource-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.55;
  margin-top: 8rpx;
  word-break: break-all;
}

.resource-action {
  flex-shrink: 0;
  margin-left: 20rpx !important;
  margin-right: 0 !important;
  background: #07c160 !important;
  color: #fff !important;
  border: none !important;
  border-radius: 999rpx !important;
  padding: 0 24rpx !important;
  line-height: 56rpx !important;
  font-size: 24rpx !important;
}

.resource-action-copy {
  background: #fff !important;
  color: #07c160 !important;
  border: 1rpx solid #07c160 !important;
}
