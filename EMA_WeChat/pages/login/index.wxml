<view class="login-page">
  <view class="login-hero">
    <text class="login-brand">EMA</text>
    <text class="login-sub">大学生心理健康 EMA 研究</text>
  </view>

  <view class="login-form">
    <view class="field">
      <text class="field-label">用户名</text>
      <input
        class="field-input"
        type="text"
        placeholder="请输入用户名"
        value="{{userName}}"
        bindinput="onUserNameInput"
        confirm-type="next"
      />
    </view>
    <view class="field">
      <text class="field-label">密码</text>
      <input
        class="field-input"
        password
        placeholder="请输入密码"
        value="{{psw}}"
        bindinput="onPswInput"
        confirm-type="done"
        bindconfirm="onSubmit"
      />
    </view>

    <view wx:if="{{error}}" class="login-error">{{error}}</view>

    <button
      class="login-btn"
      type="primary"
      loading="{{loading}}"
      disabled="{{loading}}"
      bindtap="onSubmit"
    >
      登录
    </button>
    <view class="login-actions">
      <text class="link-btn" bindtap="openChangePwd">修改密码</text>
    </view>
    <view class="login-hint">仅支持普通用户登录；管理员请使用 Web 端</view>
  </view>

  <view wx:if="{{pwdVisible}}" class="pwd-mask" catchtouchmove="noop">
    <view class="pwd-panel" catchtap="noop">
      <view class="pwd-title">修改密码</view>
      <view class="field">
        <text class="field-label">用户名</text>
        <input
          class="field-input"
          type="text"
          placeholder="请输入用户名"
          value="{{pwdUserName}}"
          bindinput="onPwdUserNameInput"
        />
      </view>
      <view class="field">
        <text class="field-label">原密码</text>
        <input
          class="field-input"
          password
          placeholder="请输入原密码"
          value="{{pwdOld}}"
          bindinput="onPwdOldInput"
        />
      </view>
      <view class="field">
        <text class="field-label">新密码</text>
        <input
          class="field-input"
          password
          placeholder="至少 6 位"
          value="{{pwdNew}}"
          bindinput="onPwdNewInput"
        />
      </view>
      <view class="field">
        <text class="field-label">确认新密码</text>
        <input
          class="field-input"
          password
          placeholder="请再次输入新密码"
          value="{{pwdConfirm}}"
          bindinput="onPwdConfirmInput"
          confirm-type="done"
          bindconfirm="onChangePassword"
        />
      </view>
      <view wx:if="{{pwdError}}" class="login-error">{{pwdError}}</view>
      <view class="pwd-footer">
        <button class="pwd-cancel" bindtap="closeChangePwd" disabled="{{pwdLoading}}">
          取消
        </button>
        <button
          class="pwd-confirm"
          type="primary"
          loading="{{pwdLoading}}"
          disabled="{{pwdLoading}}"
          bindtap="onChangePassword"
        >
          确认修改
        </button>
      </view>
    </view>
  </view>
</view>
