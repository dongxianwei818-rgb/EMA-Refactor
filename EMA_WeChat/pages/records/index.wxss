.records-page {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.records-summary {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 32rpx;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.25);
}

.records-summary-count {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1.1;
}

.records-summary-label {
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 8rpx;
}

.records-summary-sub {
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 12rpx;
}

.records-empty {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.session-group {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #eef0f2;
}

.session-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 28rpx 32rpx;
  background: #f7faf8;
  border-bottom: 1rpx solid #e8ece9;
}

.session-header-left {
  flex: 1;
  min-width: 0;
}

.session-badge {
  display: inline-block;
  background: #07c160;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  line-height: 1.4;
}

.session-date {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  margin-top: 16rpx;
}

.session-header-right {
  text-align: right;
  flex-shrink: 0;
  margin-left: 24rpx;
}

.session-count {
  font-size: 28rpx;
  font-weight: 600;
  color: #07c160;
}

.session-time {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.session-body {
  padding: 8rpx 0;
}

.record-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f2f4;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item-type {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  margin-top: 4rpx;
  max-width: 140rpx;
  text-align: center;
  line-height: 1.3;
}

.type-questionnaire {
  background: #e8f4ff;
  color: #1677ff;
}

.type-diary {
  background: #fff3e0;
  color: #e65100;
}

.type-voice {
  background: #f3e8ff;
  color: #7b1fa2;
}

.type-video {
  background: #fce4ec;
  color: #c2185b;
}

.type-steps {
  background: #e8f5e9;
  color: #2e7d32;
}

.record-item-main {
  flex: 1;
  min-width: 0;
}

.record-item-summary {
  font-size: 28rpx;
  color: #333;
  line-height: 1.55;
  word-break: break-all;
}

.record-item-time {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 10rpx;
}
