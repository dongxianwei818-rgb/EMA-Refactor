<view class="page-pad">
  <view class="card">
    <view class="hint">今日提示</view>
    <text style="font-size:30rpx;line-height:1.6;">{{prompt}}</text>
  </view>
  <view class="hint">请写 30–100 字（可提取情绪词、自我指向、压力事件等文本特征）</view>
  <textarea style="width:100%;min-height:220rpx;background:#fff;padding:24rpx;border-radius:12rpx;box-sizing:border-box;" maxlength="{{maxLen}}" placeholder="请输入…" bindinput="onInput" value="{{text}}" />
  <view style="text-align:right;color:{{valid?'#07c160':'#999'}};margin:12rpx 0;">{{len}} / {{minLen}}–{{maxLen}} 字</view>
  <button class="btn-primary" disabled="{{!valid || submitting}}" loading="{{submitting}}" bindtap="onSubmit">提交日记</button>
</view>
