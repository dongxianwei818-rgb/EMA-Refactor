@import './icon.wxss';

page {
  background: #f5f6f8;
  font-size: 28rpx;
  color: #333;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.btn-primary {
  background: #07c160 !important;
  color: #fff !important;
  border-radius: 12rpx;
  margin-top: 24rpx;
}
.btn-primary[disabled] {
  background: #c8c8c8 !important;
}
.btn-secondary {
  background: #fff !important;
  color: #07c160 !important;
  border: 1rpx solid #07c160 !important;
  border-radius: 12rpx;
  margin-top: 16rpx;
}
.btn-revoke {
  background: #fff !important;
  color: #e64340 !important;
  border: 1rpx solid #e64340 !important;
  border-radius: 12rpx;
  margin-top: 16rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin: 16rpx 0;
}
.hint {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
  margin-bottom: 20rpx;
}
.required-mark {
  color: #e64340;
}
.page-pad {
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
}
.interval-hint {
  background: #fff8e6;
  color: #996600;
}
