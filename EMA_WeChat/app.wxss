@import "./icon.wxss";

page {
  background: #f5f6f8;
  font-size: 28rpx;
  color: #333;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.btn-primary {
  background: #07c160 !important;
  color: #fff !important;
  border: none !important;
  border-radius: 12rpx;
  margin-top: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 2.2;
}
.btn-primary::after {
  border: none !important;
}
.btn-primary[disabled] {
  background: #c8c8c8 !important;
  color: #fff !important;
}
/* 查看知情同意 / 退出登录 */
.btn-secondary {
  background: #fff !important;
  color: #07c160 !important;
  border: 2rpx solid #07c160 !important;
  border-radius: 12rpx;
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 2.2;
}
.btn-secondary::after {
  border: none !important;
}
.btn-secondary[disabled] {
  color: #8fd9b0 !important;
  border-color: #8fd9b0 !important;
}
/* 撤回授权 */
.btn-revoke {
  background: #fff !important;
  color: #304ccc !important;
  border: 2rpx solid #304ccc !important;
  border-radius: 12rpx;
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 2.2;
}
.btn-revoke::after {
  border: none !important;
}
/* 退出研究 */
.btn-exit {
  background: #fff !important;
  color: #e64340 !important;
  border: 2rpx solid #e64340 !important;
  border-radius: 12rpx;
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 2.2;
}
.btn-exit::after {
  border: none !important;
}
.btn-exit-study {
  background: #fff !important;
  color: #df79f2 !important;
  border: 2rpx solid #df79f2 !important;
  border-radius: 12rpx;
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 2.2;
}
.btn-exit-study::after {
  border: none !important;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin: 16rpx 0;
}
.hint {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
  margin-bottom: 20rpx;
}
.required-mark {
  color: #e64340;
}
.page-pad {
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
}
.interval-hint {
  background: #fff8e6;
  color: #996600;
}
