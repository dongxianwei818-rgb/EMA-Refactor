# MySQL（按客户端类型分库：wechat→DB_NAME，web→DB_NAME_WEB，app→DB_NAME_APP）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ema
DB_NAME_WEB=ema_web
DB_NAME_APP=ema_app
DB_USER=dxw
DB_PASSWORD=1qaz!QAZ

# 微信小程序（生产环境必填）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 开发模式：code 直接映射为 mock_openid_{code}
MOCK_WX_LOGIN=true

# JWT
JWT_SECRET=ema-change-this-secret-in-production
JWT_EXPIRE_MINUTES=10080

# 服务
API_PREFIX=/api/v1
WEB_API_PREFIX=/api/web/v1
CORS_ORIGINS=*

# EMA 问卷趋势：span 越大曲线越平滑；history_days 为 trend_curves 保留的曲线点数
QUESTIONS_EMA_SPAN=7          # 平滑窗口，越大越平滑
QUESTIONS_EMA_HISTORY_DAYS=30 # trend_curves 保留点数

# 如果未设置 TEXT_EMBEDDING_MODEL，提取器将使用内置的 lexical-proxy-v1 向量。
# TEXT_EMBEDDING_MODEL=
# 如果设置了 TEXT_EMBEDDING_MODEL，提取器将使用指定的模型。
# 首次提取时会从 Hugging Face 下载模型,需要较长时间, 
# 国内下载模型时可设置HF_ENDPOINT=https://hf-mirror.com（需先 pip install sentence-transformers）：
# HF_ENDPOINT=https://hf-mirror.com
# TEXT_EMBEDDING_MODEL=shibing624/text2vec-base-chinese

# 如果提前下载了模型，可以设置TEXT_EMBEDDING_MODEL=你的模型路径
# 本地模型（已下载到 models/text2vec-base-chinese，无需联网）
TEXT_EMBEDDING_MODEL=models/text2vec-base-chinese

# 语音 ASR（faster-whisper）；留空则仅声学特征
# 预下载：python scripts/download_whisper.py  →  models/whisper-base
# VOICE_ASR_MODEL=base
VOICE_ASR_MODEL=models/whisper-base
VOICE_ASR_LANGUAGE=zh
VOICE_DELETE_AUDIO_AFTER_EXTRACT=false


# 视频特性提取（OpenCV 解码 MP4；推荐 mediapipe 面部网格）
# lightweight：只存视觉特征 JSON
# research：知情同意后可保留原始视频路径
VIDEO_SAMPLE_FPS=2.0
VIDEO_MAX_FRAMES=120
VIDEO_FACE_BACKEND=mediapipe
VIDEO_STORAGE_MODE=lightweight
VIDEO_DELETE_AFTER_EXTRACT=false

# 步数特性：个体化基线与低步数判定（相对基线比例，非绝对阈值）
STEP_BASELINE_WINDOW_DAYS=14
STEP_SHORT_AVG_DAYS=7
STEP_LOW_RATIO=0.4
STEP_RHYTHM_WINDOW_DAYS=28

# 用户小程序使用行为特性：打卡依从性与昼夜节律
BEHAVIOR_ON_TIME_MINUTES=60
BEHAVIOR_LATE_HOUR_START=22
BEHAVIOR_LATE_HOUR_END=5